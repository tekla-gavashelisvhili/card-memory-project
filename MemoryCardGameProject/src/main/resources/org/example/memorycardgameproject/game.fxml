<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="700.0" prefHeight="700.0"
            style="-fx-background-color: #0d0d1a;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.memorycardgameproject.GameController">

    <top>
        <HBox spacing="16.0" alignment="CENTER"
              style="-fx-background-color: #1a1a2e; -fx-border-color: #2a2a3e; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="12.0" bottom="12.0" left="24.0" right="24.0"/>
            </padding>

            <VBox alignment="CENTER" spacing="2.0">
                <Label text="Score" style="-fx-font-size: 10px; -fx-text-fill: #555577;"/>
                <Label fx:id="scoreLabel" text="0"
                       style="-fx-font-size: 20px; -fx-text-fill: #00ffe7; -fx-font-weight: bold;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER" spacing="2.0">
                <Label text="Combo" style="-fx-font-size: 10px; -fx-text-fill: #555577;"/>
                <Label fx:id="comboLabel" text="x1"
                       style="-fx-font-size: 20px; -fx-text-fill: #ffcc00; -fx-font-weight: bold;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER" spacing="2.0">
                <Label text="Time" style="-fx-font-size: 10px; -fx-text-fill: #555577;"/>
                <Label fx:id="timeLabel" text="60"
                       style="-fx-font-size: 26px; -fx-text-fill: #ff6b00; -fx-font-weight: bold;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER" spacing="2.0">
                <Label text="Moves" style="-fx-font-size: 10px; -fx-text-fill: #555577;"/>
                <Label fx:id="movesLabel" text="0"
                       style="-fx-font-size: 20px; -fx-text-fill: #bf00ff; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
    </top>

    <center>
        <GridPane fx:id="gridPane" alignment="CENTER" hgap="10.0" vgap="10.0">
            <padding>
                <Insets top="20.0" bottom="20.0" left="20.0" right="20.0"/>
            </padding>
        </GridPane>
    </center>

    <bottom>
        <HBox spacing="12.0" alignment="CENTER"
              style="-fx-background-color: #1a1a2e; -fx-border-color: #2a2a3e; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="12.0" bottom="12.0" left="14.0" right="14.0"/>
            </padding>

            <Button text="Restart" onAction="#restartGame"
                    prefWidth="110.0" prefHeight="36.0"
                    style="-fx-background-color: #00ffe720; -fx-background-radius: 8; -fx-text-fill: #00ffe7; -fx-font-size: 13px; -fx-border-color: #00ffe7; -fx-border-radius: 8; -fx-border-width: 1; -fx-cursor: hand;"/>

            <Button fx:id="hintButton" text="Hint" onAction="#useHint"
                    prefWidth="110.0" prefHeight="36.0"
                    style="-fx-background-color: #ffcc0020; -fx-background-radius: 8; -fx-text-fill: #ffcc00; -fx-font-size: 13px; -fx-border-color: #ffcc00; -fx-border-radius: 8; -fx-border-width: 1; -fx-cursor: hand;"/>

            <Button text="Menu" onAction="#goToMenu"
                    prefWidth="110.0" prefHeight="36.0"
                    style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #666677; -fx-font-size: 13px; -fx-border-color: #333344; -fx-border-radius: 8; -fx-border-width: 1; -fx-cursor: hand;"/>
        </HBox>
    </bottom>

</BorderPane>
