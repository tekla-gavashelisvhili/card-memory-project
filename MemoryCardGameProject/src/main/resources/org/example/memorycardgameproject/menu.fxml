<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="24.0" prefWidth="500.0" prefHeight="500.0"
      style="-fx-background-color: #0d0d1a;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.memorycardgameproject.MenuController">

    <padding>
        <Insets top="40.0" bottom="40.0" left="40.0" right="40.0"/>
    </padding>

    <fx:define>
        <ToggleGroup fx:id="difficultyGroup"/>
    </fx:define>

    <Label text="🧠 MEMORY MATCH"
           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #00ffe7; -fx-effect: dropshadow(gaussian, #00ffe7, 20, 0.6, 0, 0);"/>

    <Label text="Test your memory!"
           style="-fx-font-size: 14px; -fx-text-fill: #888899;"/>

    <VBox alignment="CENTER" spacing="10.0" prefWidth="300.0"
          style="-fx-background-color: #1a1a2e; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, #00ffe750, 15, 0.3, 0, 0);">
        <padding>
            <Insets top="24.0" bottom="24.0" left="24.0" right="24.0"/>
        </padding>

        <Label text="SELECT DIFFICULTY"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555577;"/>

        <ToggleButton fx:id="btnEasy" text="⚡  EASY  —  4×4  |  60s"
                      toggleGroup="$difficultyGroup" selected="true"
                      prefWidth="260.0" prefHeight="44.0"
                      style="-fx-background-color: #00ffe720; -fx-background-radius: 10; -fx-text-fill: #00ffe7; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: #00ffe7; -fx-border-radius: 10; -fx-border-width: 1.5; -fx-cursor: hand;"/>

        <ToggleButton fx:id="btnMedium" text="🔥  MEDIUM  —  6×6  |  90s"
                      toggleGroup="$difficultyGroup"
                      prefWidth="260.0" prefHeight="44.0"
                      style="-fx-background-color: #ff6b0020; -fx-background-radius: 10; -fx-text-fill: #ff6b00; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: #ff6b00; -fx-border-radius: 10; -fx-border-width: 1.5; -fx-cursor: hand;"/>

        <ToggleButton fx:id="btnHard" text="💀  HARD  —  8×8  |  120s"
                      toggleGroup="$difficultyGroup"
                      prefWidth="260.0" prefHeight="44.0"
                      style="-fx-background-color: #ff003c20; -fx-background-radius: 10; -fx-text-fill: #ff003c; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: #ff003c; -fx-border-radius: 10; -fx-border-width: 1.5; -fx-cursor: hand;"/>
    </VBox>

    <Button text="▶   START GAME" onAction="#startGame"
            prefWidth="260.0" prefHeight="50.0"
            style="-fx-background-color: #00ffe7; -fx-background-radius: 12; -fx-text-fill: #0d0d1a; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #00ffe7, 18, 0.5, 0, 0);"/>

    <Button text="EXIT" onAction="#exitGame"
            prefWidth="120.0" prefHeight="36.0"
            style="-fx-background-color: transparent; -fx-text-fill: #444466; -fx-font-size: 12px; -fx-border-color: #333355; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;"/>

</VBox>
